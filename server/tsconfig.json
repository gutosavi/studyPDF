{
  "compilerOptions": {
    "target": "ES2020",          // Versão do JavaScript de saída
    "module": "ESNext",          // Módulos ES (por causa do "type": "module")
    // "moduleResolution": "nodenext", // Resolução de módulos do Node.js
    "outDir": "./dist",          // Pasta de saída dos arquivos compilados
    "rootDir": "./src",          // Pasta raiz dos arquivos TypeScript
    "strict": true,              // Modo estrito (recomendado)
    "esModuleInterop": true,     // Permite interoperabilidade entre CommonJS e ES Modules
    "skipLibCheck": true,        // Pula a verificação de tipos de bibliotecas (acelera a compilação)
    "forceConsistentCasingInFileNames": true  // Evita problemas com case-sensitive em sistemas como Linux
  },
  "include": ["src/**/*"],       // Inclui todos os arquivos .ts em src/
  "exclude": ["node_modules"]    // Exclui node_modules
}
